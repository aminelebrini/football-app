{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "command": [
    "npx",
    "expo",
    "start",
    "--web",
    "--host",
    "lan"
  ],
  "environment": [
    "CI=1"
  ]
}